{"timestamp":"2025-10-05T18:42:56.020278Z","level":"info","event":"Running statement: -- Create Driver Career Stats Datamart\nCREATE TABLE dm_driver_career_stats AS\nWITH driver_season_stats AS (\n    SELECT \n        d.driverid,\n        d.driverref,\n        d.number AS driver_number,\n        d.code AS driver_code,\n        d.forename || ' ' || d.surname AS driver_name,\n        d.nationality AS driver_nationality,\n        r.year AS season,\n        c.name AS constructor_name,\n        c.nationality AS constructor_nationality,\n        \n        -- Race Counts\n        COUNT(DISTINCT res.raceid) AS races_entered,\n        COUNT(DISTINCT CASE WHEN res.position = 1 THEN res.raceid END) AS races_won,\n        COUNT(DISTINCT CASE WHEN res.position IN (1,2,3) THEN res.raceid END) AS podiums,\n        COUNT(DISTINCT CASE WHEN res.positiontext = 'D' THEN res.raceid END) AS dnfs,\n        \n        -- Points and Positions\n        SUM(res.points) AS total_points,\n        AVG(res.points) AS avg_points_per_race,\n        AVG(CASE WHEN res.position IS NOT NULL THEN res.position END) AS avg_finishing_position,\n        MIN(res.position) AS best_finish,\n        \n        -- Grid vs Finish Performance\n        AVG(res.grid) AS avg_grid_position,\n        AVG(res.grid - res.position) AS avg_position_gain,\n        \n        -- Fastest Laps\n        COUNT(DISTINCT CASE WHEN res.fastestlap = 1 THEN res.raceid END) AS fastest_laps\n        \n    FROM lake_results res\n    JOIN lake_drivers d ON res.driverid = d.driverid\n    JOIN lake_races r ON res.raceid = r.raceid\n    JOIN lake_constructors c ON res.constructorid = c.constructorid\n    GROUP BY \n        d.driverid, d.driverref, d.number, d.code, d.forename, d.surname, \n        d.nationality, r.year, c.name, c.nationality\n),\n\ncareer_totals AS (\n    SELECT \n        driverid,\n        COUNT(DISTINCT season) AS seasons_competed,\n        MIN(season) AS first_season,\n        MAX(season) AS last_season,\n        SUM(races_entered) AS career_races,\n        SUM(races_won) AS career_wins,\n        SUM(podiums) AS career_podiums,\n        SUM(total_points) AS career_points,\n        SUM(fastest_laps) AS career_fastest_laps\n    FROM driver_season_stats\n    GROUP BY driverid\n)\n\nSELECT \n    ds.*,\n    ct.seasons_competed,\n    ct.first_season,\n    ct.last_season,\n    ct.career_races,\n    ct.career_wins,\n    ct.career_podiums,\n    ct.career_points,\n    ct.career_fastest_laps,\n    \n    -- Calculated Metrics\n    ROUND(ct.career_wins * 100.0 / NULLIF(ct.career_races, 0), 2) AS win_percentage,\n    ROUND(ct.career_podiums * 100.0 / NULLIF(ct.career_races, 0), 2) AS podium_percentage,\n    ROUND(ds.avg_points_per_race, 2) AS avg_points_per_race_rounded,\n    ROUND(ds.avg_finishing_position, 2) AS avg_finish_rounded\n    \nFROM driver_season_stats ds\nJOIN career_totals ct ON ds.driverid = ct.driverid, parameters: None","logger":"airflow.task.hooks.airflow.providers.postgres.hooks.postgres.PostgresHook","filename":"sql.py","lineno":810}
